{
  "PreToolUse": [
    {
      "matcher": "*",
      "hooks": [
        {
          "type": "command",
          "command": "python3 \".claude/hooks/hookify/hooks/pretooluse.py\"",
          "timeout": 10
        }
      ],
      "_apm_source": "hookify"
    }
  ],
  "PostToolUse": [
    {
      "matcher": "*",
      "hooks": [
        {
          "type": "command",
          "command": "python3 \".claude/hooks/hookify/hooks/posttooluse.py\"",
          "timeout": 10
        }
      ],
      "_apm_source": "hookify"
    },
    {
      "matcher": "Edit|Write|MultiEdit|NotebookEdit",
      "hooks": [
        {
          "type": "command",
          "command": "bash \".claude/hooks/security-guidance/hooks/sg-python.sh\" \".claude/hooks/security-guidance/hooks/security_reminder_hook.py\""
        }
      ],
      "_apm_source": "security-guidance"
    },
    {
      "matcher": "Bash",
      "hooks": [
        {
          "type": "command",
          "if": "Bash(git commit:*)",
          "asyncRewake": true,
          "rewakeMessage": "Background security review of commit \u2014 address or acknowledge the findings below, then continue with the user's original request or continue waiting for their reply:",
          "rewakeSummary": "Commit security review found issues",
          "command": "bash \".claude/hooks/security-guidance/hooks/sg-python.sh\" \".claude/hooks/security-guidance/hooks/security_reminder_hook.py\""
        },
        {
          "type": "command",
          "if": "Bash(git push:*)",
          "asyncRewake": true,
          "rewakeMessage": "Background security review of pushed commits not yet reviewed \u2014 address or acknowledge the findings below, then continue with the user's original request or continue waiting for their reply:",
          "rewakeSummary": "Push security review found issues",
          "command": "bash \".claude/hooks/security-guidance/hooks/sg-python.sh\" \".claude/hooks/security-guidance/hooks/security_reminder_hook.py\""
        },
        {
          "type": "command",
          "if": "Bash(gt create:*)",
          "asyncRewake": true,
          "rewakeMessage": "Background security review of commit \u2014 address or acknowledge the findings below, then continue with the user's original request or continue waiting for their reply:",
          "rewakeSummary": "Commit security review found issues",
          "command": "bash \".claude/hooks/security-guidance/hooks/sg-python.sh\" \".claude/hooks/security-guidance/hooks/security_reminder_hook.py\""
        },
        {
          "type": "command",
          "if": "Bash(gt modify:*)",
          "asyncRewake": true,
          "rewakeMessage": "Background security review of commit \u2014 address or acknowledge the findings below, then continue with the user's original request or continue waiting for their reply:",
          "rewakeSummary": "Commit security review found issues",
          "command": "bash \".claude/hooks/security-guidance/hooks/sg-python.sh\" \".claude/hooks/security-guidance/hooks/security_reminder_hook.py\""
        },
        {
          "type": "command",
          "if": "Bash(gt submit:*)",
          "asyncRewake": true,
          "rewakeMessage": "Background security review of pushed commits not yet reviewed \u2014 address or acknowledge the findings below, then continue with the user's original request or continue waiting for their reply:",
          "rewakeSummary": "Push security review found issues",
          "command": "bash \".claude/hooks/security-guidance/hooks/sg-python.sh\" \".claude/hooks/security-guidance/hooks/security_reminder_hook.py\""
        }
      ],
      "_apm_source": "security-guidance"
    }
  ],
  "Stop": [
    {
      "matcher": "*",
      "hooks": [
        {
          "type": "command",
          "command": "python3 \".claude/hooks/hookify/hooks/stop.py\"",
          "timeout": 10
        }
      ],
      "_apm_source": "hookify"
    },
    {
      "matcher": "*",
      "hooks": [
        {
          "type": "command",
          "asyncRewake": true,
          "rewakeMessage": "Background security review feedback \u2014 address or acknowledge the findings below, then continue with the user's original request or continue waiting for their reply. This is supplementary, not a replacement for your previous response:",
          "rewakeSummary": "Background security review found issues",
          "command": "bash \".claude/hooks/security-guidance/hooks/sg-python.sh\" \".claude/hooks/security-guidance/hooks/security_reminder_hook.py\""
        }
      ],
      "_apm_source": "security-guidance"
    }
  ],
  "UserPromptSubmit": [
    {
      "matcher": "*",
      "hooks": [
        {
          "type": "command",
          "command": "python3 \".claude/hooks/hookify/hooks/userpromptsubmit.py\"",
          "timeout": 10
        }
      ],
      "_apm_source": "hookify"
    },
    {
      "matcher": "*",
      "hooks": [
        {
          "type": "command",
          "command": "bash \".claude/hooks/security-guidance/hooks/sg-python.sh\" \".claude/hooks/security-guidance/hooks/security_reminder_hook.py\""
        }
      ],
      "_apm_source": "security-guidance"
    }
  ],
  "SessionStart": [
    {
      "matcher": "*",
      "hooks": [
        {
          "type": "command",
          "command": "bash \".claude/hooks/security-guidance/hooks/sg-python.sh\" \".claude/hooks/security-guidance/hooks/ensure_agent_sdk.py\"",
          "timeout": 180
        }
      ],
      "_apm_source": "security-guidance"
    },
    {
      "matcher": "startup|clear|compact",
      "hooks": [
        {
          "type": "command",
          "async": false,
          "command": "\".claude/hooks/superpowers/hooks/run-hook.cmd\" session-start"
        }
      ],
      "_apm_source": "superpowers"
    }
  ]
}
